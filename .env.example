# ----- Clerk Auth -----
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding
CLERK_WEBHOOK_SECRET=whsec_...

# ----- Razorpay (active payment provider) -----
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Plan IDs created in the Razorpay dashboard. Each plan is per-employee.
# Growth: ₹500/employee/month, ₹5,000/employee/year (10x monthly).
# Business: ₹800/employee/month, ₹8,000/employee/year (10x monthly).
RAZORPAY_GROWTH_MONTHLY_PLAN_ID=
RAZORPAY_GROWTH_ANNUAL_PLAN_ID=
RAZORPAY_BUSINESS_MONTHLY_PLAN_ID=
RAZORPAY_BUSINESS_ANNUAL_PLAN_ID=

# ----- Resend (Email) -----
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ----- Sentry -----
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=sntrys_...
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=your-project-slug

# ----- PostHog -----
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ----- App -----
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----- Superadmin (founder-only console at /superadmin/*) -----
# Cookie value compared against the superadmin_session cookie. Required for
# /superadmin/dashboard, /superadmin/social, /superadmin/feedback to load.
# SUPERADMIN_SESSION_TOKEN is preferred; SUPERADMIN_SECRET kept for backwards-compat.
SUPERADMIN_SECRET=
# SUPERADMIN_SESSION_TOKEN=

# ----- JambaHire Referrals -----
# Master kill switch for /dashboard/refer/* + /hire/referrals + /apply/r/[token].
# Pages 404 and sidebar entry hides when this is anything other than 'true'.
JAMBAHIRE_REFERRALS_ENABLED=false

# ----- Social Agent (LinkedIn content automation, single-tenant under /superadmin) -----
# Master kill switch — must be 'true' for the generation cron to actually run
SOCIAL_AGENT_ENABLED=false

# Anthropic (already used elsewhere — caption generation)
ANTHROPIC_API_KEY=sk-ant-...

# Cloudflare Workers AI (Flux Schnell — image generation, free tier)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_AI_TOKEN=

# Buffer (publish to LinkedIn page via the Buffer queue)
BUFFER_ACCESS_TOKEN=
BUFFER_ORG_ID=
BUFFER_LINKEDIN_CHANNEL_ID=
# Override only if Buffer's GraphQL endpoint changes
# BUFFER_GRAPHQL_URL=https://api.buffer.com/graphql

# AI Assistant (Phase 0)
AI_GATEWAY_API_KEY=
NEXT_PUBLIC_ASSISTANT_ENABLED=false

# AI Assistant (Phase 1 — Voyage embeddings for app-help semantic search)
VOYAGE_API_KEY=
