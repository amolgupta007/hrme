{
  "framework": "nextjs",
  "buildCommand": "next build",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "regions": ["bom1"],
  "crons": [
    {
      "path": "/api/cron/doc-reminders",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/api/cron/training-reminders",
      "schedule": "0 9 * * 3"
    },
    {
      "path": "/api/cron/onboarding-nudges",
      "schedule": "30 3 * * *"
    },
    {
      "path": "/api/cron/billing-grace-period",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/webhook-events-cleanup",
      "schedule": "0 5 * * 0"
    },
    {
      "path": "/api/cron/attendance-auto-clockout",
      "schedule": "30 18 * * *"
    },
    {
      "path": "/api/cron/social-agent-generate",
      "schedule": "0 4 * * 1,3,5"
    },
    {
      "path": "/api/cron/social-agent-publish-check",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/onetime-nudge?day=3&to=vinay@medialoop.in&name=Vinay&org=Medialoop%20Communications",
      "schedule": "30 4 18 5 *"
    },
    {
      "path": "/api/cron/onetime-nudge?day=5&to=vinay@medialoop.in&name=Vinay&org=Medialoop%20Communications",
      "schedule": "30 4 20 5 *"
    },
    {
      "path": "/api/cron/loi-expiry",
      "schedule": "15 4 * * *"
    },
    {
      "path": "/api/cron/assistant-doc-reindex",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/assistant-redact",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/jambageo-followup-reminders",
      "schedule": "30 3 * * *"
    },
    {
      "path": "/api/cron/jambageo-retention-sweep",
      "schedule": "0 19 * * *"
    },
    {
      "path": "/api/cron/late-policy-reconcile",
      "schedule": "0 20 * * *"
    },
    {
      "path": "/api/cron/indeed-sync-reconcile",
      "schedule": "45 4 * * *"
    }
  ]
}
